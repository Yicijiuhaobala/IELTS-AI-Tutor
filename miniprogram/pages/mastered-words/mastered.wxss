.container {
  min-height: 100vh;
  background: var(--bg-primary);
}

.page-header {
  background: #fff;
  padding: 24rpx 24rpx 16rpx;
  box-shadow: var(--shadow-sm);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.back-btn {
  font-size: 28rpx;
  color: var(--primary);
}

.accent-toggle {
  font-size: 22rpx;
  color: var(--primary);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.search-input {
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}

.word-list {
  padding: 16rpx 24rpx;
}

.word-item {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.word-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.word-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.word-phonetic {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.sound-btn {
  font-size: 28rpx;
  padding: 4rpx;
}

.word-meaning {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.word-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 2;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  opacity: 0.7;
}
