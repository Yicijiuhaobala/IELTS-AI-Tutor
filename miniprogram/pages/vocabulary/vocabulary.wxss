.container {
  padding-bottom: 40rpx;
}

.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 24rpx;
}

.mode-item {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mode-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.daily-words {
  margin: 0 24rpx;
}

.word-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.word-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.word-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.word-phonetic {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.word-meaning {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.word-example {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-style: italic;
  padding: 12rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
}

.example-text {
  flex: 1;
}

.example-sound {
  flex-shrink: 0;
}

.word-status {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: right;
}

.word-status.mastered {
  color: var(--success);
}

.synonym-practice {
  margin: 0 24rpx;
}

.synonym-input {
  margin-bottom: 16rpx;
  min-height: 160rpx;
}

.synonym-result {
  margin: 0 24rpx;
}

.pair-list {
  background: #fff;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.pair-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.pair-item:last-child {
  border-bottom: none;
}

.pair-left, .pair-right {
  flex: 1;
  font-size: 26rpx;
}

.pair-left {
  color: var(--text-secondary);
  text-align: right;
  padding-right: 16rpx;
}

.pair-right {
  color: var(--primary);
  font-weight: 500;
  padding-left: 16rpx;
}

.pair-arrow {
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.pattern-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.result-section {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.result-section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--primary);
}

.back-btn {
  font-size: 26rpx;
  color: var(--primary);
  margin-right: 16rpx;
}

.mode-content {
  background: #fff;
  border-radius: var(--radius-md);
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.content-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
  white-space: pre-wrap;
}

.loading-tip {
  text-align: center;
  padding: 60rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.title-actions {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  float: right;
}

.accent-btn {
  font-size: 22rpx;
  color: var(--primary);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.refresh-btn {
  font-size: 22rpx;
  color: var(--text-secondary);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.word-phonetic-area {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sound-btn {
  font-size: 28rpx;
  padding: 4rpx;
}

.mastered-toggle {
  margin: 16rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.mastered-list {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.mastered-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.mastered-item:last-child {
  border-bottom: none;
}

.mastered-word {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 100%;
  margin-bottom: 4rpx;
}

.word-phonetic-small {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.mastered-meaning {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
}

.mastered-date {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.empty-state-small {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}
