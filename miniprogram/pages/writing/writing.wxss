.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.task-selector {
  padding: 32rpx 24rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.task-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  margin-right: 24rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 600;
}

.task-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}

.history-info {
  flex: 1;
}

.history-task {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.history-preview {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.history-score {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.editor {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.editor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}

.editor-title {
  font-size: 32rpx;
  font-weight: 600;
}

.editor-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.editor-body {
  flex: 1;
  padding: 24rpx;
}

.question-card {
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.question-label {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.question-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.word-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: right;
  margin-bottom: 12rpx;
}

.essay-input {
  width: 100%;
  min-height: 400rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.8;
  box-sizing: border-box;
  border: 2rpx solid var(--border);
}

.editor-footer {
  padding: 20rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid var(--border);
}

.btn-primary.disabled {
  opacity: 0.5;
}

.result-area {
  flex: 1;
  padding: 24rpx;
}

.result-header {
  text-align: center;
  padding: 40rpx;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.result-score {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--primary);
}

.result-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.dimension-scores {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.dim-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dim-item:last-child {
  margin-bottom: 0;
}

.dim-label {
  width: 200rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.dim-bar {
  flex: 1;
  height: 16rpx;
  background: var(--bg-secondary);
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
}

.dim-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  width: 48rpx;
  text-align: right;
}

.result-section {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.result-section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--primary);
}

.result-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  white-space: pre-wrap;
}

.result-text.improved {
  color: var(--text-primary);
  background: var(--bg-secondary);
  padding: 16rpx;
  border-radius: var(--radius-sm);
  font-style: italic;
}

.vocab-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.vocab-tag {
  background: var(--primary-light);
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
}

.result-actions {
  padding: 16rpx 0 40rpx;
}

.result-actions .btn-primary {
  margin-bottom: 16rpx;
}
