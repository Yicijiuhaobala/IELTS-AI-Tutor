.container {
  padding-bottom: 40rpx;
}

.profile-header {
  text-align: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--primary) 0%, #6CB4EE 100%);
  color: #fff;
}

.avatar {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-target {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 0 24rpx;
}

.overview-item {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.overview-item.clickable:active {
  opacity: 0.7;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.streak-card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.streak-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.streak-count {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--warning);
}

.streak-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.streak-grid {
  display: flex;
  justify-content: space-between;
}

.streak-day {
  text-align: center;
}

.day-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.day-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  margin: 0 auto;
}

.streak-day.active .day-dot {
  background: var(--success);
}

.streak-day.today .day-dot {
  border: 4rpx solid var(--primary);
  background: var(--primary-light);
}

.today-detail {
  margin: 0 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.history-tabs {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
}

.tab {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: var(--bg-secondary);
  color: var(--text-secondary);
}

.tab.active {
  background: var(--primary);
  color: #fff;
}

.history-list {
  margin: 0 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}

.history-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.history-content {
  flex: 1;
}

.history-title {
  font-size: 26rpx;
  color: var(--text-primary);
}

.history-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.settings {
  margin: 0 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
}

.setting-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}
