.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.mode-selector {
  padding: 32rpx 24rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.mode-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  margin-right: 24rpx;
}

.mode-title {
  font-size: 32rpx;
  font-weight: 600;
}

.mode-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.session {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.session-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}

.session-mode {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.session-btn {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  background: var(--bg-secondary);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.chat-area {
  flex: 1;
  padding: 24rpx;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: var(--bg-secondary);
  margin: 0 16rpx;
  flex-shrink: 0;
}

.msg-content {
  max-width: 70%;
}

.msg-text {
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  line-height: 1.6;
  box-shadow: var(--shadow-sm);
  white-space: pre-wrap;
}

.message.user .msg-text {
  background: var(--primary);
  color: #fff;
}

.msg-time {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.message.user .msg-time {
  text-align: right;
}

.thinking-dots {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--text-tertiary);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid var(--border);
  gap: 16rpx;
}

.input-wrapper {
  flex: 1;
}

.input-wrapper .input-box {
  margin: 0;
}

.send-btn {
  background: var(--primary);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.score-panel {
  padding: 32rpx;
  background: #fff;
  border-top: 1rpx solid var(--border);
}

.score-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
}

.score-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.score-item {
  flex: 1;
  min-width: 40%;
  text-align: center;
  padding: 16rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
}

.score-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
}

.score-value.high { color: var(--success); }
.score-value.mid { color: var(--warning); }
.score-value.low { color: var(--danger); }

.score-total {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  color: var(--primary);
  margin-bottom: 24rpx;
}

.score-advice {
  margin-bottom: 24rpx;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.advice-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
  padding-left: 24rpx;
  position: relative;
}

.advice-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--primary);
}

.score-panel .btn-primary {
  margin-bottom: 16rpx;
}
