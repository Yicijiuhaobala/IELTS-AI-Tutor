page {
  --primary: #4A90D9;
  --primary-light: #E8F0FE;
  --primary-dark: #357ABD;
  --success: #34C759;
  --warning: #FF9500;
  --danger: #FF3B30;
  --text-primary: #1C1C1E;
  --text-secondary: #6C6C70;
  --text-tertiary: #AEAEB2;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F7FA;
  --bg-tertiary: #E8F0FE;
  --border: #E5E5EA;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.card {
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-md);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.input-box {
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  border: 2rpx solid var(--border);
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.tag {
  display: inline-block;
  background: var(--primary-light);
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-success {
  background: #E8F8E8;
  color: var(--success);
}

.tag-warning {
  background: #FFF3E0;
  color: var(--warning);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--text-tertiary);
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--text-tertiary);
}

.empty-state text {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-state view {
  font-size: 28rpx;
}
